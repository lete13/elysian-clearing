# Copy this to .env for local development
# On Railway, set these in the Variables tab

# Your Hosthub API key (Settings → API Keys in Hosthub)
# When set, no user needs to enter it in the app
HOSTHUB_API_KEY=your_hosthub_key_here

# Team password — required to open the app (HTTP Basic Auth)
APP_PASSWORD=your_team_password

# Automatically set by Railway when you add a PostgreSQL database
# For local dev: postgresql://user:pass@localhost:5432/elysian
DATABASE_URL=postgresql://...

# Viva bank bridge (Payments Check tab) — Account Transactions Credentials
# Generate in your Viva account: Settings → API Access → Account Transactions Credentials
# When set, the Saturday 08:00 auto-check of received payouts switches on automatically
VIVA_TX_USER=your_viva_tx_username
VIVA_TX_PASS=your_viva_tx_password
# 'live' (default) or 'demo'
VIVA_ENV=live
